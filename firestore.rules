rules_version = '2';

// ══════════════════════════════════════════════════════════════
// SGM · TRANSPOWER — Reglas Firestore (Fase 16 · schema v2)
// ──────────────────────────────────────────────────────────────
// Cambios respecto a F14:
//   · `transformadores` migra a shape v2: sección `identificacion`,
//     sección `ubicacion`, `estado_servicio` (enum ampliado con
//     'fallado'), `schema_version == 2`. Se mantiene compat con
//     el shape v1 aplanado (proyección v1) para que las vistas
//     legacy sigan funcionando; los `allow create`/`allow update`
//     aceptan payloads que traigan ambos niveles.
//   · Nueva colección `subestaciones`.
//   · Nuevas subcolecciones append-only `transformadores/{id}/
//     placas_historicas` y `transformadores/{id}/historial_hi`.
//   · Las escrituras siguen restringidas a `isAdmin()` mientras
//     F28 (RBAC granular con ámbito geográfico) entra.
//
// Referencia: MO.00418.DE-GAC-AX.01 Ed. 02 — §4.1 (variables), §4.2
// (ponderación HI), §A9 (protocolos).
// ══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers de sesión / rol ──
    function isSignedIn() { return request.auth != null; }

    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isTeamMember() {
      return isSignedIn() && (
        (hasProfile() && profile().activo == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        (hasProfile() && profile().rol == 'admin' && profile().activo == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ── Helpers de validación de enums v2 ──
    function isTipoActivoValido(v) {
      return v in ['POTENCIA', 'TPT', 'RESPALDO'];
    }
    function isEstadoServicioValido(v) {
      return v in ['operativo', 'mantenimiento', 'fuera_servicio', 'retirado', 'fallado'];
    }
    function isZonaValida(v) {
      return v in ['BOLIVAR', 'ORIENTE', 'OCCIDENTE'];
    }
    function isDeptoValido(v) {
      return v in ['bolivar', 'cordoba', 'sucre', 'cesar', 'magdalena'];
    }
    function isGrupoValido(v) {
      return v == '' || v == null || v in ['G1', 'G2', 'G3'];
    }

    // ── /admins/{uid} — legacy bootstrap (F5) ──
    match /admins/{uid} {
      allow read:  if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── /usuarios/{uid} — perfiles (F14) ──
    // F28 extenderá a los 5 roles oficiales (director_proyectos,
    // analista_tx, gestor_contractual, brigadista, auditor_campo).
    // En F16 se mantiene la lista v1 + aceptación del rol legacy
    // 'tecnico' (los perfiles actuales no rompen).
    match /usuarios/{uid} {
      allow get:    if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'email','rol','activo'
                       ])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.rol in [
                        'admin','tecnico',
                        'director_proyectos','analista_tx',
                        'gestor_contractual','brigadista','auditor_campo'
                       ]
                    && request.resource.data.activo is bool;
      allow update: if isAdmin()
                    && (!('rol' in request.resource.data)
                        || request.resource.data.rol in [
                            'admin','tecnico',
                            'director_proyectos','analista_tx',
                            'gestor_contractual','brigadista','auditor_campo'
                           ])
                    && (!('activo' in request.resource.data)
                        || request.resource.data.activo is bool);
      allow delete: if isAdmin() && request.auth.uid != uid;
    }

    // ── /subestaciones/{id} (Fase 16) ──
    // La UI dedicada entra en F20. F16 sólo expone CRUD admin
    // para que el importador F17 pueda poblar la colección.
    match /subestaciones/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','nombre','departamento'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.nombre is string
                    && request.resource.data.nombre.size() > 0
                    && isDeptoValido(request.resource.data.departamento)
                    && (!('zona' in request.resource.data)
                        || request.resource.data.zona == ''
                        || isZonaValida(request.resource.data.zona));
      allow update: if isAdmin()
                    && (!('departamento' in request.resource.data)
                        || isDeptoValido(request.resource.data.departamento))
                    && (!('zona' in request.resource.data)
                        || request.resource.data.zona == ''
                        || isZonaValida(request.resource.data.zona));
      allow delete: if isAdmin();
    }

    // ── /transformadores/{id} — schema v2 ──
    // Shape aceptado:
    //   schema_version: 2
    //   estado_servicio: enum
    //   identificacion: { codigo, nombre, tipo_activo, uucc?, grupo? }
    //   ubicacion: { departamento, zona?, ... }
    //   placa, electrico, mecanico, refrigeracion, protecciones,
    //   fabricacion, servicio, salud_actual, criticidad
    //
    // Además se permiten campos de proyección v1 en el nivel raíz
    // (codigo, nombre, departamento, estado, ...) para compat con
    // vistas legacy que todavía consultan por ellos. Las rules
    // validan AMBOS niveles como coherentes cuando el payload
    // trae los dos.
    match /transformadores/{id} {

      allow read: if isTeamMember();

      allow create: if isAdmin()
        && request.resource.data.schema_version == 2
        && request.resource.data.keys().hasAll(['identificacion','ubicacion','estado_servicio'])
        && request.resource.data.identificacion.keys().hasAll(['codigo','nombre','tipo_activo'])
        && request.resource.data.identificacion.codigo is string
        && request.resource.data.identificacion.codigo.size() > 0
        && request.resource.data.identificacion.nombre is string
        && request.resource.data.identificacion.nombre.size() > 0
        && isTipoActivoValido(request.resource.data.identificacion.tipo_activo)
        && isGrupoValido(request.resource.data.identificacion.get('grupo', ''))
        && isDeptoValido(request.resource.data.ubicacion.departamento)
        && (!('zona' in request.resource.data.ubicacion)
            || request.resource.data.ubicacion.zona == ''
            || isZonaValida(request.resource.data.ubicacion.zona))
        && isEstadoServicioValido(request.resource.data.estado_servicio)
        // Proyección v1 (si está presente) debe ser consistente.
        && (!('codigo' in request.resource.data)
            || request.resource.data.codigo == request.resource.data.identificacion.codigo)
        && (!('estado' in request.resource.data)
            || request.resource.data.estado == request.resource.data.estado_servicio
            || (request.resource.data.estado_servicio == 'fallado'
                && request.resource.data.estado == 'retirado'));

      allow update: if isAdmin()
        && (!('schema_version' in request.resource.data)
            || request.resource.data.schema_version == 2)
        && (!('estado_servicio' in request.resource.data)
            || isEstadoServicioValido(request.resource.data.estado_servicio))
        && (!('identificacion' in request.resource.data)
            || !('tipo_activo' in request.resource.data.identificacion)
            || isTipoActivoValido(request.resource.data.identificacion.tipo_activo))
        && (!('identificacion' in request.resource.data)
            || !('grupo' in request.resource.data.identificacion)
            || isGrupoValido(request.resource.data.identificacion.grupo))
        && (!('ubicacion' in request.resource.data)
            || !('departamento' in request.resource.data.ubicacion)
            || isDeptoValido(request.resource.data.ubicacion.departamento))
        && (!('ubicacion' in request.resource.data)
            || !('zona' in request.resource.data.ubicacion)
            || request.resource.data.ubicacion.zona == ''
            || isZonaValida(request.resource.data.ubicacion.zona));

      allow delete: if isAdmin();

      // ── /transformadores/{id}/placas_historicas/{evt} ──
      // Append-only: trazabilidad de retrofits. F16 reserva el
      // shape; la UI para registrar cambios entra en F23.
      match /placas_historicas/{evt} {
        allow read:   if isTeamMember();
        allow create: if isAdmin()
                      && request.resource.data.tipo_cambio in [
                          'potencia','tension','refrigeracion','tap','otro'
                         ];
        allow update: if false;
        allow delete: if false;
      }

      // ── /transformadores/{id}/historial_hi/{calculo} ──
      // Append-only: snapshots del Health Index. Cada re-cálculo
      // del motor (F18) o cambio de umbrales genera una entrada.
      match /historial_hi/{calculo} {
        allow read:   if isTeamMember();
        allow create: if isAdmin()
                      && request.resource.data.trigger in [
                          'muestra_nueva','parametros_actualizados',
                          'migracion_v2','manual','override_experto',
                          'recalculo_masivo'
                         ];
        allow update: if false;
        allow delete: if false;
      }

      // ── /transformadores/{id}/historial/{evt} (legacy de F7) ──
      // Se mantiene por compat con órdenes viejas. El mismo alias
      // de subcolección no existe; este match es defensivo.
      match /historial/{evt} {
        allow read:   if isTeamMember();
        allow create: if isAdmin();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── /ordenes/{id} (sin cambios en F16, migra en F23) ──
    match /ordenes/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','titulo','transformadorId',
                        'estado','tipo','prioridad'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.estado in [
                        'planificada','en_curso','cerrada','cancelada'
                       ]
                    && request.resource.data.tipo in [
                        'preventivo','correctivo','predictivo','emergencia'
                       ]
                    && request.resource.data.prioridad in [
                        'baja','media','alta','critica'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.estado in [
                        'planificada','en_curso','cerrada','cancelada'
                       ]
                    && request.resource.data.tipo in [
                        'preventivo','correctivo','predictivo','emergencia'
                       ]
                    && request.resource.data.prioridad in [
                        'baja','media','alta','critica'
                       ];
      allow delete: if isAdmin();

      match /historial/{evt} {
        allow read:   if isTeamMember();
        allow create: if isAdmin();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── /documentos/{id} (sin cambios en F16) ──
    match /documentos/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','titulo','categoria','norma_aplicable'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.categoria in [
                        'protocolo','informe','certificado','manual','reporte','otro'
                       ]
                    && request.resource.data.norma_aplicable in [
                        'ISO_50001','IEEE_C57_12','IEC_60076',
                        'RETIE','NTC_IEC_60364','CIGRE_WG_A2','NINGUNA'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.categoria in [
                        'protocolo','informe','certificado','manual','reporte','otro'
                       ]
                    && request.resource.data.norma_aplicable in [
                        'ISO_50001','IEEE_C57_12','IEC_60076',
                        'RETIE','NTC_IEC_60364','CIGRE_WG_A2','NINGUNA'
                       ];
      allow delete: if isAdmin();
    }

    match /alertas_config/{id} {
      allow read:   if isTeamMember();
      allow write:  if isAdmin();
    }

    match /alertas_reconocidas/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.alertId is string
                    && request.resource.data.alertId.size() > 0;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Gate legacy F12 cerrado ──
    match /gate_codes/{hash} {
      allow read, write: if false;
    }

    // ── Resto: cerrado por defecto ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
