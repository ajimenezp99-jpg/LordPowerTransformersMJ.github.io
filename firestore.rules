rules_version = '2';

// ══════════════════════════════════════════════════════════════
// SGM · TRANSPOWER — Reglas Firestore (Fase 14)
// Modelo unificado: toda lectura requiere sesión activa y perfil
// en /usuarios/{uid} con `activo=true`. Las escrituras las hace
// únicamente quien tenga rol 'admin' en el perfil, o quien esté
// en la colección heredada /admins/{uid} (bootstrap de F5).
// Colecciones: transformadores (F6), ordenes (F7), documentos
// (F9, metadata), alertas_config + alertas_reconocidas (F11),
// usuarios (F14, roles del equipo).
// ══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Miembro activo del equipo. Admite bootstrap por /admins/{uid}
    // para no bloquear al propietario durante la migración desde F5.
    function isTeamMember() {
      return isSignedIn() && (
        (hasProfile() && profile().activo == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Admin. Puede ser por rol='admin' en /usuarios, o por el doc
    // legacy /admins/{uid} heredado de F5.
    function isAdmin() {
      return isSignedIn() && (
        (hasProfile() && profile().rol == 'admin' && profile().activo == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ── /admins/{uid} ──
    // Documento marcador legacy de F5. Se mantiene como bootstrap
    // para el propietario. El contenido no se usa.
    match /admins/{uid} {
      allow read:  if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── /usuarios/{uid} — F14 ──
    // Perfil del miembro del equipo: email, nombre, rol, activo.
    // - Cada usuario puede leer su propio perfil (para que el guard
    //   verifique estado y rol).
    // - Admins pueden listar y gestionar todos los perfiles.
    match /usuarios/{uid} {
      allow get:    if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'email','rol','activo'
                       ])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.rol in ['admin','tecnico']
                    && request.resource.data.activo is bool;
      allow update: if isAdmin()
                    && (!('rol' in request.resource.data)
                        || request.resource.data.rol in ['admin','tecnico'])
                    && (!('activo' in request.resource.data)
                        || request.resource.data.activo is bool);
      allow delete: if isAdmin() && request.auth.uid != uid;
    }

    // ── /transformadores/{id} ──
    match /transformadores/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','nombre','departamento','estado'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.estado in [
                        'operativo','mantenimiento','fuera_servicio','retirado'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.estado in [
                        'operativo','mantenimiento','fuera_servicio','retirado'
                       ];
      allow delete: if isAdmin();
    }

    // ── /ordenes/{id} ──
    match /ordenes/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','titulo','transformadorId',
                        'estado','tipo','prioridad'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.estado in [
                        'planificada','en_curso','cerrada','cancelada'
                       ]
                    && request.resource.data.tipo in [
                        'preventivo','correctivo','predictivo','emergencia'
                       ]
                    && request.resource.data.prioridad in [
                        'baja','media','alta','critica'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.estado in [
                        'planificada','en_curso','cerrada','cancelada'
                       ]
                    && request.resource.data.tipo in [
                        'preventivo','correctivo','predictivo','emergencia'
                       ]
                    && request.resource.data.prioridad in [
                        'baja','media','alta','critica'
                       ];
      allow delete: if isAdmin();

      // Historial inmutable — sólo escribir (append-only).
      match /historial/{evt} {
        allow read:   if isTeamMember();
        allow create: if isAdmin();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── /documentos/{id} ──
    match /documentos/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','titulo','categoria','norma_aplicable'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.categoria in [
                        'protocolo','informe','certificado','manual','reporte','otro'
                       ]
                    && request.resource.data.norma_aplicable in [
                        'ISO_50001','IEEE_C57_12','IEC_60076',
                        'RETIE','NTC_IEC_60364','CIGRE_WG_A2','NINGUNA'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.categoria in [
                        'protocolo','informe','certificado','manual','reporte','otro'
                       ]
                    && request.resource.data.norma_aplicable in [
                        'ISO_50001','IEEE_C57_12','IEC_60076',
                        'RETIE','NTC_IEC_60364','CIGRE_WG_A2','NINGUNA'
                       ];
      allow delete: if isAdmin();
    }

    // ── /alertas_config/{id} ──
    match /alertas_config/{id} {
      allow read:   if isTeamMember();
      allow write:  if isAdmin();
    }

    // ── /alertas_reconocidas/{id} ──
    match /alertas_reconocidas/{id} {
      allow read:   if isTeamMember();
      allow create: if isAdmin()
                    && request.resource.data.alertId is string
                    && request.resource.data.alertId.size() > 0;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── /gate_codes/{hash} — DEPRECADO (F12) ──
    // El gate de códigos fue retirado en F14 (login unificado). Se
    // mantiene la colección cerrada por si quedan datos residuales
    // de la fase anterior; ninguna página del sitio la lee ya.
    match /gate_codes/{hash} {
      allow read, write: if false;
    }

    // ── Resto: cerrado por defecto ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
