rules_version = '2';

// ══════════════════════════════════════════════════════════════
// SGM · TRANSPOWER — Reglas Firestore (Fase 9)
// Colecciones activas: `transformadores` (F6), `ordenes` (F7)
// y `documentos` (F9, metadata · binarios en Storage).
// Estado admin se enforce vía colección /admins/{uid}.
// ══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── /admins/{uid} ──
    // Documento marcador. El contenido no se usa (puede tener {active: true}).
    // Se crea y mantiene desde la consola Firebase por el propietario.
    match /admins/{uid} {
      allow read:  if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── /transformadores/{id} ──
    // Lectura pública (el gate estático del sitio ya filtra visitantes).
    // Escritura restringida a admins en la allowlist de /admins.
    match /transformadores/{id} {
      allow read:   if true;
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','nombre','departamento','estado'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.estado in [
                        'operativo','mantenimiento','fuera_servicio','retirado'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.estado in [
                        'operativo','mantenimiento','fuera_servicio','retirado'
                       ];
      allow delete: if isAdmin();
    }

    // ── /ordenes/{id} ──
    // Órdenes de trabajo vinculadas a un transformador.
    // Lectura pública (filtrada por gate estático).
    // Escritura restringida a admins en la allowlist.
    match /ordenes/{id} {
      allow read:   if true;
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','titulo','transformadorId',
                        'estado','tipo','prioridad'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.estado in [
                        'planificada','en_curso','cerrada','cancelada'
                       ]
                    && request.resource.data.tipo in [
                        'preventivo','correctivo','predictivo','emergencia'
                       ]
                    && request.resource.data.prioridad in [
                        'baja','media','alta','critica'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.estado in [
                        'planificada','en_curso','cerrada','cancelada'
                       ]
                    && request.resource.data.tipo in [
                        'preventivo','correctivo','predictivo','emergencia'
                       ]
                    && request.resource.data.prioridad in [
                        'baja','media','alta','critica'
                       ];
      allow delete: if isAdmin();

      // Historial inmutable — sólo escribir (append-only).
      match /historial/{evt} {
        allow read:   if true;
        allow create: if isAdmin();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── /documentos/{id} ──
    // Metadata de archivos técnicos almacenados en Storage.
    // Lectura pública (filtrada por gate estático).
    // Escritura restringida a admins con validación de enums.
    match /documentos/{id} {
      allow read:   if true;
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll([
                        'codigo','titulo','categoria','norma_aplicable'
                       ])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() > 0
                    && request.resource.data.categoria in [
                        'protocolo','informe','certificado','manual','reporte','otro'
                       ]
                    && request.resource.data.norma_aplicable in [
                        'ISO_50001','IEEE_C57_12','IEC_60076',
                        'RETIE','NTC_IEC_60364','CIGRE_WG_A2','NINGUNA'
                       ];
      allow update: if isAdmin()
                    && request.resource.data.categoria in [
                        'protocolo','informe','certificado','manual','reporte','otro'
                       ]
                    && request.resource.data.norma_aplicable in [
                        'ISO_50001','IEEE_C57_12','IEC_60076',
                        'RETIE','NTC_IEC_60364','CIGRE_WG_A2','NINGUNA'
                       ];
      allow delete: if isAdmin();
    }

    // ── Resto: cerrado por defecto ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
